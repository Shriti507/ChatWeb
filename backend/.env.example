# Copy to .env and fill in real values (never commit .env).
#
# Supabase: Project Settings → Database → Connection string.
# - Use the "Transaction" pooler URL for DATABASE_URL (port 6543, often includes ?pgbouncer=true).
# - Use the "Direct" or "Session" connection for DIRECT_URL (port 5432) so migrations work.
# Do not leave the literal text USER, PASSWORD, or HOST — those must be your real user, password, and host.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Required for JWT auth
JWT_SECRET="replace-with-a-long-random-secret"
